{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@ui/*": ["../../packages/ui/src/*", "./components/ui/*"],
      "@server/*": ["./server/*", "./lib/*"],
      "@types/*": ["./types/*"],
      "@config/*": ["../../packages/config/src/*", "./config/*"],
      "@features/*": ["./features/*"],
      "@pulseguard/db": ["../../packages/db/src/index"],
      "@pulseguard/sdk": ["../../packages/sdk/src/index"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
