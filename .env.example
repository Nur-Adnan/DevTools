# =========================================================================
# PULSEGUARD MASTER ENVIRONMENT CONFIGURATION TEMPLATE (.env.example)
# =========================================================================
# This template outlines all environment variables required for running
# the monorepo application. Copy this file to '.env' or '.env.local' and
# populate it with your credentials.

# -------------------------------------------------------------------------
# 1. Node & Application Runtime
# -------------------------------------------------------------------------
# Node environment. Values: "development" | "production" | "test"
NODE_ENV=development

# Base URL of the client application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -------------------------------------------------------------------------
# 2. Database Layer (Prisma + Neon PostgreSQL)
# -------------------------------------------------------------------------
# Connection string to Neon PostgreSQL database. Ensure pooling parameters match.
DATABASE_URL="postgresql://username:password@ep-host-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"

# -------------------------------------------------------------------------
# 3. Identity & Authentication (Clerk)
# -------------------------------------------------------------------------
# Public Publishable Key found in the Clerk Dashboard under API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Secret Key found in the Clerk Dashboard (Keep secure, Server-side only)
CLERK_SECRET_KEY=sk_test_...

# Secret Signing Key for verifying webhook payloads sent from Clerk to PulseGuard
CLERK_WEBHOOK_SECRET=whsec_...

# Authentication Redirect URL paths
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# -------------------------------------------------------------------------
# 4. Redis Polymorphic Layer (Rate Limiting, Cache, Sessions)
# -------------------------------------------------------------------------
# Polymorphic client operational mode. Values: "local" | "upstash"
REDIS_MODE=local

# Local Redis host connection (used when REDIS_MODE=local)
REDIS_URL=redis://localhost:6379

# Upstash REST URL for serverless Redis environments (used when REDIS_MODE=upstash)
UPSTASH_REDIS_REST_URL=https://...upstash.io

# Upstash REST Token for secure serverless API access (used when REDIS_MODE=upstash)
UPSTASH_REDIS_REST_TOKEN=gQ...
